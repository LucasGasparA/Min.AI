# Banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/legisla"

# JWT - gere com: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET="troque-por-um-secret-longo-e-aleatorio"

# ── Vertex AI (Google Cloud) ──────────────────────────────────────────
# ID do projeto no Google Cloud Console
GCP_PROJECT_ID="meu-projeto-gcp"

# Região do Vertex AI (padrão: us-central1)
GCP_LOCATION="us-central1"

# Modelo a usar (padrão: gemini-1.5-pro)
# Outros: gemini-2.0-flash, gemini-1.0-pro
GCP_MODEL="gemini-1.5-pro"

# Autenticação: aponte para o arquivo JSON da service account
# Sem isso, usa Application Default Credentials (gcloud auth application-default login)
GOOGLE_APPLICATION_CREDENTIALS="/caminho/para/service-account.json"

# Porta do servidor (padrão 4000)
PORT=4000
