# Banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/legisla"

# JWT - gere com: openssl rand -base64 64
JWT_SECRET="troque-por-um-secret-longo-e-aleatorio"

# Google Gemini API (opcional - sem ela o sistema usa modo mock)
GEMINI_API_KEY=""

# Porta do servidor (padrão 4000)
PORT=4000
